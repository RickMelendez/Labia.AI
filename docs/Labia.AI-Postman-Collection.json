            "body": {
              "mode": "raw",
              "raw": "{\n  \"received_message\": \"Me la paso súper bien hablando contigo. ¿Qué te parece si nos vemos pronto?\",\n  \"cultural_style\": \"boricua\",\n  \"relationship_stage\": \"advanced\",\n  \"shared_interests\": [\"música\", \"comida\", \"cine\"],\n  \"num_suggestions\": 3\n}"
            },
