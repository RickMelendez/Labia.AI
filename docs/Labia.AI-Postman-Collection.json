{
  "info": {
    "name": "Labia.AI API - Puerto Rico & Latin Market",
    "_postman_id": "labia-ai-collection",
    "description": "Complete API collection for Labia.AI - AI conversation assistant for Puerto Rican and Latin American users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "api_version",
      "value": "v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/health",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "health"]
            }
          }
        },
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/ping",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "ping"]
            }
          }
        },
        {
          "name": "Root - Wepa!",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Conversation Openers",
      "item": [
        {
          "name": "Generate Puerto Rican Openers",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Me encanta la playa, el mofongo y Bad Bunny 🐰 Trabajo en marketing digital y siempre estoy buscando nuevas aventuras.\",\n  \"interests\": [\"playa\", \"música\", \"marketing\", \"viajes\"],\n  \"cultural_style\": \"boricua\",\n  \"user_interests\": [\"música\", \"deportes\"],\n  \"num_suggestions\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/openers",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "openers"]
            }
          }
        },
        {
          "name": "Generate Mexican Openers",
