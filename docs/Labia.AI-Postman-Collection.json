      ]
    },
    {
      "name": "Content Safety",
      "item": [
        {
          "name": "Check Safe Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hola, ¿cómo estás? Me gustaría conocerte mejor y saber más sobre tus intereses.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/responses/safety-check",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "responses", "safety-check"]
            }
          }
        },
        {
          "name": "Check Inappropriate Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"[Contenido inapropiado para prueba]\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/responses/safety-check",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "responses", "safety-check"]
            }
          }
        },
        {
          "name": "Rewrite Inappropriate Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"[Mensaje inapropiado que necesita ser reescrito]\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/responses/rewrite?cultural_style=boricua",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "responses", "rewrite"],
              "query": [
                {
                  "key": "cultural_style",
                  "value": "boricua"
                }
              ]
            }
          }
        }
      ]
    },
