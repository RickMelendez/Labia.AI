# Labia.AI - Staging Environment Variables
# This is for pre-production testing

# ==================== Application ====================
ENVIRONMENT=staging
DEBUG=True  # More verbose logging for debugging
APP_NAME=Labia.AI

# ==================== Database ====================
# Use separate staging database to avoid affecting production
DATABASE_URL=postgresql://labiaai:labiaai@staging-db.labia.chat:5432/labiaai_staging

# ==================== Redis ====================
# Use separate staging Redis instance
REDIS_URL=redis://staging-redis.labia.chat:6379/0
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT_TTL=86400

# ==================== LLM Configuration ====================
# Use cheaper model for staging to save costs
LLM_PROVIDER=openai

# OpenAI - Use GPT-3.5 for staging (cheaper)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo  # Cheaper than GPT-4 for testing

# Anthropic - Or use Claude Haiku (cheapest)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ==================== Security & JWT ====================
# IMPORTANT: Use different secrets for staging!
SECRET_KEY=your-staging-secret-key-change-this-min-32-chars
JWT_SECRET_KEY=your-staging-jwt-secret-key-change-this-must-be-64-chars-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Rate Limiting ====================
# More relaxed limits for testing
RATE_LIMIT_FREE=20
RATE_LIMIT_PRO=200
RATE_LIMIT_PREMIUM=-1

# ==================== CORS ====================
# Staging domains
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19000,http://localhost:19006,https://staging.labia.chat,https://api.staging.labia.chat

# ==================== Default Settings ====================
DEFAULT_CULTURAL_STYLE=boricua
DEFAULT_TONE=chill
