# Labia.AI - Production Environment Variables
# This is for live production deployment

# ==================== Application ====================
ENVIRONMENT=production
DEBUG=False  # IMPORTANT: Must be False in production!
APP_NAME=Labia.AI

# ==================== Database ====================
# Use managed PostgreSQL service (AWS RDS, DigitalOcean, etc.)
DATABASE_URL=postgresql://labiaai_prod:CHANGE_THIS_PASSWORD@prod-db.labia.chat:5432/labiaai_prod

# ==================== Redis ====================
# Use managed Redis service (AWS ElastiCache, DigitalOcean, etc.)
REDIS_URL=redis://prod-redis.labia.chat:6379/0
REDIS_CACHE_TTL=3600  # 1 hour
REDIS_RATE_LIMIT_TTL=86400  # 24 hours

# ==================== LLM Configuration ====================
# Choose your LLM provider
LLM_PROVIDER=openai  # or anthropic

# OpenAI Configuration
OPENAI_API_KEY=sk-prod-REPLACE-WITH-YOUR-PRODUCTION-OPENAI-KEY
OPENAI_MODEL=gpt-4-turbo-preview  # Or gpt-3.5-turbo to save costs

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-REPLACE-WITH-YOUR-PRODUCTION-ANTHROPIC-KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ==================== Security & JWT ====================
# CRITICAL: Generate strong random secrets! DO NOT use these defaults!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_THIS_WITH_STRONG_RANDOM_SECRET_32_CHARS_MINIMUM
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=REPLACE_THIS_WITH_STRONG_RANDOM_JWT_SECRET_64_CHARS_MINIMUM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Rate Limiting ====================
# Production rate limits per plan
RATE_LIMIT_FREE=10      # 10 requests per day
RATE_LIMIT_PRO=100      # 100 requests per day
RATE_LIMIT_PREMIUM=-1   # Unlimited

# ==================== CORS ====================
# Only allow production domains
ALLOWED_ORIGINS=https://labia.chat,https://www.labia.chat,https://api.labia.chat

# ==================== Default Settings ====================
DEFAULT_CULTURAL_STYLE=boricua
DEFAULT_TONE=chill

# ==================== Monitoring (Optional) ====================
# Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==================== Email (Future Feature) ====================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# EMAIL_FROM=noreply@labia.chat
